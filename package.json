{
  "name": "account-control",
  "version": "1.0.0",
  "type": "module",
  "description": "aplicação com leitura de arquivos, testes unitarios e cache com redis",
  "main": "src/index.js",
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "restore": "cp __tests__/seed.json src/users.json",
    "start": "node src/index.js",
    "dev": "nodemon src/index.js --ignore 'src/users.json'"
  },
  "keywords": [],
