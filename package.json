  "license": "ISC",
  "dependencies": {
    "body-parser": "1.19.0",
    "express": "4.17.1",
    "express-rescue": "1.1.30",
    "ioredis": "^5.10.1",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "chai": "4.3.4",
    "eslint": "^10.2.1",
    "frisby": "2.1.3",
    "globals": "^17.5.0",
    "jest": "^29.7.0",
    "mocha": "8.4.0",
    "nodemon": "2.0.15",
    "nyc": "15.1.0",
    "sinon": "11.1.1"
  }
}
